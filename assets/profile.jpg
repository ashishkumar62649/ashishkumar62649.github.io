<svg xmlns="http://www.w3.org/2000/svg" width="400" height="400" viewBox="0 0 400 400">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#111118"/>
      <stop offset="100%" style="stop-color:#1a1a2e"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00b4d8"/>
      <stop offset="100%" style="stop-color:#7b61ff"/>
    </linearGradient>
  </defs>
  <rect width="400" height="400" fill="url(#bg)"/>
  <circle cx="200" cy="160" r="60" fill="none" stroke="url(#accent)" stroke-width="2" opacity="0.5"/>
  <circle cx="200" cy="160" r="40" fill="url(#accent)" opacity="0.15"/>
  <text x="200" y="170" text-anchor="middle" fill="#e8e8ed" font-family="Inter, sans-serif" font-size="48" font-weight="700">AK</text>
  <text x="200" y="320" text-anchor="middle" fill="#555566" font-family="Inter, sans-serif" font-size="14">Replace with your photo</text>
  <text x="200" y="340" text-anchor="middle" fill="#555566" font-family="Inter, sans-serif" font-size="12">assets/profile.jpg</text>
</svg>
